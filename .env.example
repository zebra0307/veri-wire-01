# Copy to `.env.local` for `pnpm dev`. Database: Supabase Postgres (not a local Postgres container).

NEXTAUTH_SECRET=replace_with_long_random_secret
NEXTAUTH_URL=http://localhost:3000

# Supabase → Project Settings → Database → Connection string (URI).
# For Prisma + pooler use Transaction mode and append: ?pgbouncer=true&connection_limit=1
DATABASE_URL=

# Optional: same project URL + service role key for Storage / admin APIs (see src/lib/supabase-server.ts)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

REDIS_URL=redis://localhost:6379
GITHUB_ID=
GITHUB_SECRET=
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=no-reply@veriwire.local
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
# Required for realtime event publishing.
# Local bridge example: http://127.0.0.1:8787
SPACETIMEDB_ENDPOINT=
# Optional bearer token expected by your bridge.
SPACETIMEDB_API_KEY=
SUPERPLANE_WEBHOOK_URL=
SUPERPLANE_SECRET=

# false = real sign-in required (/login). true = synthetic demo moderator + optional /api/seed (local only).
DEMO_BYPASS_AUTH=false

APP_URL=http://localhost:3000
DOMAIN=localhost
INTERNAL_AGENT_SECRET=dev-agent-secret

# Optional: ArmorIQ intent verification for VeriAgent (https://platform.armoriq.ai). Same flow as armoriq-sdk Python client.
# ARMORIQ_API_KEY=ak_test_...
# ARMORIQ_USER_ID=optional-fixed-user-when-no-session
# ARMORIQ_AGENT_ID=veriwire-veriagent
# ARMORIQ_CONTEXT_ID=default
# ARMORIQ_ENV=production
# ARMORIQ_STRICT=false
# ARMORIQ_BACKEND_URL=
# ARMORIQ_PROXY_URL=
# Per-MCP proxy override: {MCP_NAME}_PROXY_URL (e.g. VERIWIRE_AGENT_PROXY_URL) — see invokeArmorIQMcpAction in src/lib/armoriq.ts
